{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for VoxFlow windows",
  "windows": [
    "main",
    "overlay"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "autostart:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-size",
    "core:window:allow-set-position"
  ]
}
