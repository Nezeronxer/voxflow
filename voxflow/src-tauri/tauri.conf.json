{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxFlow",
  "version": "2.0.4",
  "identifier": "com.nezeronxer.voxflow.macos",
  "build": {
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "VoxFlow",
        "width": 1180,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "visible": false,
        "resizable": true,
        "center": true
      },
      {
        "label": "overlay",
        "url": "index.html#/overlay",
        "width": 266,
        "height": 60,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "resizable": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "VoxFlow",
    "copyright": "© 2026 VoxFlow",
    "category": "Productivity",
    "shortDescription": "Локальный голосовой ввод",
    "longDescription": "VoxFlow — локальная диктовка: горячая клавиша → речь → чистый текст в активном окне. Локальный режим работает по умолчанию; облачные провайдеры подключаются только со своим ключом.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/whisper/Release/*",
      "resources/whisper-cuda/Release/*",
      "resources/vad/*"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Russian"],
        "installerIcon": "icons/icon-mono.ico",
        "headerImage": "installer/installer-header.bmp",
        "sidebarImage": "installer/installer-sidebar.bmp",
        "uninstallerIcon": "icons/icon-mono.ico",
        "installerHooks": "installer/hooks.nsh"
      }
    }
  }
}
